# Copy this file to infra/.env and fill values before running bootstrap.sh

GCP_PROJECT_ID=
GCP_PROJECT_NUMBER=
GCP_REGION=
CLOUD_RUN_SERVICE=
ARTIFACT_REPO=
GCS_BUCKET_NAME=
GCP_DEPLOY_SERVICE_ACCOUNT=
GCP_RUNTIME_SERVICE_ACCOUNT=
GCP_WORKLOAD_IDENTITY_POOL=
GCP_WORKLOAD_IDENTITY_PROVIDER_ID=
GITHUB_REPOSITORY=owner/repo
CLOUD_RUN_PUBLIC_ORIGIN=
FIREBASE_SITE_ID=

# Optional rate-limit/runtime overrides
PER_IP_BURST_COUNT=5
PER_IP_BURST_WINDOW_SECONDS=10
PER_IP_SUSTAINED_COUNT=30
PER_IP_SUSTAINED_WINDOW_SECONDS=60
MAX_MESSAGE_CHARS=500
MAX_WS_PAYLOAD_BYTES=4096
IP_STATE_TTL_SECONDS=600
RATE_METRICS_LOG_INTERVAL_SECONDS=60
